# Local database (runtime artifact)
*.db

# .NET build artifacts
bin/
obj/
[Dd]ebug/
[Rr]elease/
publish/
*.user

# OS files
.DS_Store
Thumbs.db

# Agent worktrees (transient, created by isolated subagents)
.claude/worktrees/

# Verification screenshots: local-only — they capture machine-specific paths
# (e.g. %APPDATA% with a real username) and don't belong in a public repo.
.scratch/blurt/screenshots/*.png

# Security audit reports: local-only — they enumerate unfixed weaknesses with
# file:line detail; publishing them before fixes ship would be a disclosure risk.
.scratch/blurt/security-audit/

# Traffic snapshot tool + its accumulated history: local-only, run "ab und zu"
# to see current GitHub traffic/downloads and keep a record past the 14-day window.
.scratch/blurt/traffic/
