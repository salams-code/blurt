<Window x:Class="Blurt.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Title="Blurt settings"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="#FFF3F3F3"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <!-- A titled section: bold header over a white card. Applied per group. -->
        <Style x:Key="GroupHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#FF202020" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#FF404040" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="BorderBrush" Value="#FFE0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="760">
        <StackPanel Margin="18">

            <!-- Transcription -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource GroupHeader}" Text="Transcription" />
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Source" />
                        <ComboBox x:Name="TranscriptionSourceBox" Grid.Column="1" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Local model size" />
                        <ComboBox x:Name="ModelSizeBox" Grid.Column="1" />
                    </Grid>
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="#FF808080"
                               FontSize="11"
                               Text="Changing the source or model size takes effect after a restart." />
                </StackPanel>
            </Border>

            <!-- Refinement -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource GroupHeader}" Text="Refinement (LLM)" />
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Base URL" />
                        <TextBox x:Name="BaseUrlBox" Grid.Column="1" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Model" />
                        <TextBox x:Name="RefinementModelBox" Grid.Column="1" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="API key" />
                        <PasswordBox x:Name="ApiKeyBox" Grid.Column="1" />
                    </Grid>
                    <TextBlock x:Name="ApiKeyHint"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="#FF808080"
                               FontSize="11"
                               Text="Leave blank to keep the stored key. Stored encrypted (DPAPI), never in plaintext." />
                </StackPanel>
            </Border>

            <!-- Hotkeys -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource GroupHeader}" Text="Hotkeys" />
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Fix" />
                        <TextBox x:Name="HotkeyFixBox" Grid.Column="1" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="English" />
                        <TextBox x:Name="HotkeyEnglishBox" Grid.Column="1" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Flex slot" />
                        <TextBox x:Name="HotkeyFlexBox" Grid.Column="1" />
                    </Grid>
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="#FF808080"
                               FontSize="11"
                               Text="Format: AltGr+, (the trigger characters , . - are supported). Each trigger needs its own key." />
                </StackPanel>
            </Border>

            <!-- Flex slot -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource GroupHeader}" Text="Flex slot" />
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Mode order" />
                        <TextBox x:Name="FlexOrderBox" Grid.Column="1" />
                    </Grid>
                    <TextBlock Margin="150,4,0,0"
                               TextWrapping="Wrap"
                               Foreground="#FF808080"
                               FontSize="11"
                               Text="Comma-separated: Pur, Bullets, Custom. The slot cycles through them in this order." />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Custom prompt"
                                   VerticalAlignment="Top" Margin="0,4,12,0" />
                        <TextBox x:Name="CustomPromptBox" Grid.Column="1"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="64"
                                 VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Overlay & sound -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource GroupHeader}" Text="Overlay &amp; sound" />
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Overlay anchor" />
                        <ComboBox x:Name="OverlayAnchorBox" Grid.Column="1" />
                    </Grid>
                    <CheckBox x:Name="SoundEnabledBox"
                              Margin="0,12,0,0"
                              Content="Play a sound on record start/stop" />
                </StackPanel>
            </Border>

            <!-- Inline validation errors (hidden until a save attempt fails) -->
            <Border x:Name="ErrorPanel"
                    Background="#FFFDECEC"
                    BorderBrush="#FFE0B4B4"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,14"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Please fix the following before saving:"
                               FontWeight="SemiBold"
                               Foreground="#FFB00020"
                               Margin="0,0,0,6" />
                    <ItemsControl x:Name="ErrorList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           TextWrapping="Wrap"
                                           Foreground="#FFB00020"
                                           Margin="0,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Width="90"
                        Height="30"
                        Margin="0,0,10,0"
                        IsCancel="True"
                        Click="OnCancel" />
                <Button x:Name="SaveButton"
                        Content="Save"
                        Width="90"
                        Height="30"
                        IsDefault="True"
                        Click="OnSave" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
