<Window x:Class="Blurt.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Title="Blurt settings"
        Icon="assets/blurt.ico"
        Width="580" Height="700"
        MinWidth="480" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        FontSize="13">
    <!-- Styles/templates come from Themes/Controls.xaml, merged by
         ThemeManager.Apply before InitializeComponent (issue 19). -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,18,20,6">

                <!-- Transcription -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GroupHeader}" Text="Transcription" />

                        <!-- Privacy tier (issue 27): the primary control, framed by what
                             leaves the machine rather than the two technical axes it maps
                             onto. Selecting a tier sets the transcription Source and the
                             refinement Provider together (Core's PrivacyTiers.SettingsFor);
                             a non-standard combo set by hand below shows as "Custom". Pur
                             stays zero-network regardless — this governs the refined modes. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Privacy" />
                            <ComboBox x:Name="PrivacyTierBox" Grid.Column="1"
                                      SelectionChanged="OnPrivacyTierChanged" />
                        </Grid>
                        <!-- Plain-language "what leaves this PC" line, set per tier. -->
                        <TextBlock x:Name="PrivacyHint"
                                   Style="{StaticResource Hint}"
                                   Margin="150,6,0,0" />

                        <!-- Advanced disclosure: the underlying transcription source and
                             local model. Hidden by default — the tier above is enough for
                             the common case; power users reveal it to override (which then
                             shows the tier as "Custom"). -->
                        <CheckBox x:Name="ShowAdvancedTranscriptionBox"
                                  Margin="150,12,0,0"
                                  Content="Advanced: transcription source &amp; local model"
                                  Checked="OnToggleAdvancedTranscription"
                                  Unchecked="OnToggleAdvancedTranscription" />
                        <StackPanel x:Name="AdvancedTranscriptionPanel"
                                    Visibility="Collapsed"
                                    Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Source" />
                                <ComboBox x:Name="TranscriptionSourceBox" Grid.Column="1"
                                          SelectionChanged="OnTranscriptionSourceChanged" />
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Local model" />
                                <ComboBox x:Name="ModelSizeBox" Grid.Column="1"
                                          SelectionChanged="OnModelSelectionChanged" />
                            </Grid>
                            <!-- Per-selection manual-install guidance (issue 18): the exact file,
                                 a working link, and the target folder, all derived from whatever
                                 model is selected — so a hand install matches what Blurt loads.
                                 Populated in OnModelSelectionChanged from the selected WhisperModel. -->
                            <TextBlock x:Name="ModelDownloadHint"
                                       Style="{StaticResource Hint}"
                                       Margin="150,8,0,0" />
                            <!-- Copy affordances (issue 25): the corporate-proxy flow is a
                                 hand install, so the URL and target folder must be copyable
                                 rather than retyped from the hint above. -->
                            <StackPanel Orientation="Horizontal" Margin="150,6,0,0">
                                <Button Content="Copy link"
                                        Style="{StaticResource LinkButton}"
                                        Click="OnCopyModelLink" />
                                <Button Content="Copy folder"
                                        Style="{StaticResource LinkButton}"
                                        Margin="14,0,0,0"
                                        Click="OnCopyModelFolder" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource Hint}"
                                       Margin="150,4,0,0"
                                       Text="The source applies from the next dictation (Pur always stays local/offline). Changing the local model takes effect after a restart." />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Microphone (issue 16) -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GroupHeader}" Text="Microphone" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Input device" />
                            <ComboBox x:Name="MicrophoneBox" Grid.Column="1" />
                        </Grid>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="(Windows default) follows the current default input, so a newly-connected headset is used automatically. Pick a specific device to pin it." />
                    </StackPanel>
                </Border>

                <!-- Refinement -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GroupHeader}" Text="Refinement (LLM)" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Provider" />
                            <ComboBox x:Name="RefinementProviderBox" Grid.Column="1"
                                      SelectionChanged="OnRefinementProviderChanged" />
                        </Grid>
                        <TextBlock x:Name="ProviderHint"
                                   Style="{StaticResource Hint}"
                                   Margin="150,6,0,0"
                                   Text="" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Base URL" />
                            <TextBox x:Name="BaseUrlBox" Grid.Column="1" />
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Model" />
                            <TextBox x:Name="RefinementModelBox" Grid.Column="1" />
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="API key" />
                            <PasswordBox x:Name="ApiKeyBox" Grid.Column="1" />
                        </Grid>
                        <TextBlock x:Name="ApiKeyHint"
                                   Style="{StaticResource Hint}"
                                   Text="Leave blank to keep the stored key. Stored encrypted (DPAPI), never in plaintext." />
                    </StackPanel>
                </Border>

                <!-- Mode prompts (issue 35): every refined mode's system prompt is
                     editable here, pre-filled with our default. An untouched field
                     keeps the default behaviour; an edit applies on the next
                     dictation, no restart. Pur has no prompt (verbatim) so it is
                     absent. Custom's prompt lives with the Flex slot below. -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GroupHeader}" Text="Mode prompts (LLM)" />
                        <TextBlock Style="{StaticResource Hint}"
                                   Margin="0,0,0,8"
                                   Text="The instructions sent to the refinement model for each mode. Edit to change how a mode rewrites your dictation; clear a field to restore its default." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Fix"
                                       VerticalAlignment="Top" Margin="0,6,12,0" />
                            <TextBox x:Name="FixPromptBox" Grid.Column="1"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="72"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="English"
                                       VerticalAlignment="Top" Margin="0,6,12,0" />
                            <TextBox x:Name="EnglishPromptBox" Grid.Column="1"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="72"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Bullets"
                                       VerticalAlignment="Top" Margin="0,6,12,0" />
                            <TextBox x:Name="BulletsPromptBox" Grid.Column="1"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="72"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Email"
                                       VerticalAlignment="Top" Margin="0,6,12,0" />
                            <TextBox x:Name="EmailPromptBox" Grid.Column="1"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="72"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                        <!-- Reset (issue 37): returns every editable prompt above AND the
                             Custom prompt below to its shipped default. Non-destructive —
                             the current prompts are backed up first, so the reset is
                             recoverable (the restore UI is issue 38). Takes effect on Save. -->
                        <Button Content="Reset prompts to defaults"
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,12,0,0"
                                Click="OnResetPrompts" />
                        <TextBlock Style="{StaticResource Hint}"
                                   Margin="0,4,0,0"
                                   Text="Restores the default wording for every mode (including the Custom prompt). Your current prompts are backed up first, then applied when you click Save." />
                    </StackPanel>
                </Border>

                <!-- Prompt backup (issue 38): see / copy / restore the prompts as they
                     were before your last change (captured automatically on save by
                     PromptBackupPolicy). The status line says whether a backup is
                     present; the toggle shows/hides its contents; Copy puts them on the
                     clipboard; Restore loads them back into the prompt fields above
                     (persisted on Save, so it takes effect on the next dictation). -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GroupHeader}" Text="Prompt backup" />
                        <TextBlock x:Name="BackupStatusText" Style="{StaticResource Hint}" />
                        <!-- Actions on top (Restore first), so the buttons are reachable
                             without scrolling past the prompt text. -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="RestoreBackupButton"
                                    Content="Restore backup"
                                    Style="{StaticResource LinkButton}"
                                    Click="OnRestoreBackup" />
                            <Button x:Name="CopyBackupButton"
                                    Content="Copy backup"
                                    Style="{StaticResource LinkButton}"
                                    Margin="14,0,0,0"
                                    Click="OnCopyBackup" />
                            <Button x:Name="ToggleBackupButton"
                                    Content="Show backed-up prompts"
                                    Style="{StaticResource LinkButton}"
                                    Margin="14,0,0,0"
                                    Click="OnToggleBackupView" />
                        </StackPanel>
                        <!-- Collapsed by default — the backed-up text only shows on demand
                             (toggled by the link above) so it stays out of the way. -->
                        <TextBox x:Name="BackupViewBox"
                                 Margin="0,8,0,0"
                                 Visibility="Collapsed"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="96"
                                 MaxHeight="180"
                                 VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>

                <!-- Hotkeys -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GroupHeader}" Text="Hotkeys" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Fix" />
                            <TextBox x:Name="HotkeyFixBox" Grid.Column="1"
                                     PreviewKeyDown="OnHotkeyPreviewKeyDown" />
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="English" />
                            <TextBox x:Name="HotkeyEnglishBox" Grid.Column="1"
                                     PreviewKeyDown="OnHotkeyPreviewKeyDown" />
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Flex slot" />
                            <TextBox x:Name="HotkeyFlexBox" Grid.Column="1"
                                     PreviewKeyDown="OnHotkeyPreviewKeyDown" />
                        </Grid>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Click a field and press the chord (e.g. AltGr+,) to set it, or type it by hand. The trigger characters , . - are supported; each trigger needs its own key." />
                    </StackPanel>
                </Border>

                <!-- Flex slot -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GroupHeader}" Text="Flex slot" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Mode order" />
                            <TextBox x:Name="FlexOrderBox" Grid.Column="1" />
                        </Grid>
                        <TextBlock Style="{StaticResource Hint}"
                                   Margin="150,6,0,0"
                                   Text="Comma-separated: Pur, Bullets, Custom, Email. The slot cycles through them in this order." />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Custom prompt"
                                       VerticalAlignment="Top" Margin="0,6,12,0" />
                            <TextBox x:Name="CustomPromptBox" Grid.Column="1"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="72"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Overlay & sound -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GroupHeader}" Text="Overlay &amp; sound" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Overlay anchor" />
                            <ComboBox x:Name="OverlayAnchorBox" Grid.Column="1" />
                        </Grid>
                        <CheckBox x:Name="SoundEnabledBox"
                                  Margin="0,14,0,0"
                                  Content="Play a sound on record start/stop" />
                    </StackPanel>
                </Border>

                <!-- Startup: per-user auto-start with Windows (no admin). The Run-key
                     presence is the source of truth — the box reflects the registry on
                     load and writes/removes it on save (WindowsStartup). -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource GroupHeader}" Text="Startup" />
                        <CheckBox x:Name="StartWithWindowsBox"
                                  Content="Start Blurt when Windows starts" />
                        <TextBlock Style="{StaticResource Hint}"
                                   Margin="0,6,0,0"
                                   Text="Launches Blurt to the tray at sign-in. Per-user, no admin needed. If you move the Blurt folder, re-toggle this so it points at the new location." />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer: validation errors + actions, pinned below the scroll area so a
             rejected save is always visible (issue 20). -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel>
                <Border x:Name="ErrorPanel"
                        Background="{DynamicResource DangerBackgroundBrush}"
                        BorderBrush="{DynamicResource DangerBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,0,0,12"
                        Focusable="True"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Please fix the following before saving:"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DangerTextBrush}"
                                   Margin="0,0,0,6" />
                        <ItemsControl x:Name="ErrorList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource DangerTextBrush}"
                                               Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Margin="0,0,10,0"
                            IsCancel="True"
                            Click="OnCancel" />
                    <Button x:Name="SaveButton"
                            Content="Save"
                            Style="{StaticResource AccentButton}"
                            IsDefault="True"
                            Click="OnSave" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
