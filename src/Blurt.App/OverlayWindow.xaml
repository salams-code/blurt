<Window x:Class="Blurt.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        ShowActivated="False"
        SizeToContent="WidthAndHeight"
        Focusable="False"
        IsHitTestVisible="False"
        FontFamily="Segoe UI">
    <!-- The pill: a rounded capsule with a coloured status dot on the left and a
         label on the right. Surface colours follow the system theme via
         ThemeManager (issue 19): light capsule on light, dark on dark. Padding/
         margins are sized so SizeToContent yields a snug pill the placement maths
         can position. -->
    <Border CornerRadius="17"
            Background="{DynamicResource PillBackgroundBrush}"
            BorderBrush="{DynamicResource PillBorderBrush}"
            BorderThickness="1"
            Padding="16,9"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.35" Color="Black" />
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse x:Name="StatusDot"
                     Width="10" Height="10"
                     VerticalAlignment="Center"
                     Fill="#DC3545" />
            <TextBlock x:Name="StatusText"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PillTextBrush}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Text="listening…" />
        </StackPanel>
    </Border>
</Window>
