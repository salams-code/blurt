<Window x:Class="Blurt.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Title="Welcome to Blurt"
        Width="580" Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        FontSize="13">
    <!-- Card/Hint and the control templates come from Themes/Controls.xaml,
         merged by ThemeManager.Apply before InitializeComponent (issue 19). -->
    <Window.Resources>
        <Style x:Key="StepTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="19" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="StepSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
    </Window.Resources>

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Step indicator -->
        <TextBlock x:Name="StepIndicator" Grid.Row="0"
                   FontSize="11"
                   Foreground="{DynamicResource TextTertiaryBrush}"
                   Margin="0,0,0,10"
                   Text="Step 1 of 4" />

        <!-- The four steps. Exactly one is visible at a time (StepPanels). -->
        <Grid Grid.Row="1">

            <!-- Step 1: Microphone -->
            <StackPanel x:Name="MicrophonePanel">
                <TextBlock Style="{StaticResource StepTitle}" Text="Choose your microphone" />
                <TextBlock Style="{StaticResource StepSubtitle}"
                           Text="Pick the input device you'll dictate with, then speak — the bar should react." />
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Input device" Margin="0,0,0,6" />
                        <ComboBox x:Name="MicrophoneBox" SelectionChanged="OnMicrophoneChanged" />
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Live level" Margin="0,16,0,6" />
                        <Border Background="{DynamicResource TrackBrush}" CornerRadius="4" Height="18">
                            <Border x:Name="LevelBar"
                                    HorizontalAlignment="Left"
                                    Width="0"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="4" />
                        </Border>
                        <TextBlock x:Name="MicStatus"
                                   Style="{StaticResource Hint}"
                                   Text="Listening for input…" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Step 2: API key -->
            <StackPanel x:Name="ApiKeyPanel" Visibility="Collapsed">
                <TextBlock Style="{StaticResource StepTitle}" Text="Choose your refinement provider (optional)" />
                <TextBlock Style="{StaticResource StepSubtitle}"
                           Text="Refinement (Fix, English, Bullets) runs through an OpenAI-compatible endpoint. Use the OpenAI cloud with a key, or a local/Ollama endpoint with no key. You can skip this entirely — dictation still works offline and falls back to the raw transcript." />
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <RadioButton x:Name="OpenAiProviderRadio"
                                     GroupName="Provider"
                                     Content="OpenAI cloud (use an API key)"
                                     IsChecked="True"
                                     Checked="OnProviderChoiceChanged" />
                        <RadioButton x:Name="LocalProviderRadio"
                                     GroupName="Provider"
                                     Margin="0,8,0,0"
                                     Content="Local / Ollama (OpenAI-compatible, no key)"
                                     Checked="OnProviderChoiceChanged" />
                    </StackPanel>
                </Border>

                <!-- OpenAI sub-step: how to get a key + entry -->
                <Border x:Name="OpenAiKeyCard" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Margin="0,0,0,8" Text="How to get a key"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,1"
                                   Text="1.  Go to platform.openai.com and sign in." />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,1"
                                   Text="2.  Open the API keys page (left menu → API keys)." />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,1"
                                   Text="3.  Click &quot;Create new secret key&quot; and copy it." />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,1,0,12"
                                   Text="4.  Paste it below." />
                        <TextBlock Style="{StaticResource FieldLabel}" Text="API key" Margin="0,0,0,6" />
                        <PasswordBox x:Name="ApiKeyBox" />
                        <TextBlock x:Name="ApiKeyHint"
                                   Style="{StaticResource Hint}"
                                   Text="Stored encrypted on this machine (DPAPI), never in plaintext. Leave blank to skip." />
                    </StackPanel>
                </Border>

                <!-- Local sub-step: point at the Ollama endpoint, no key needed -->
                <Border x:Name="LocalEndpointCard" Style="{StaticResource Card}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Margin="0,0,0,8" Text="Local / Ollama endpoint"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,1,0,12"
                                   Text="Run an OpenAI-compatible server (e.g. Ollama) and point Blurt at it. No API key is needed; any stored key is kept but not sent." />
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Base URL" Margin="0,0,0,6" />
                        <TextBox x:Name="LocalBaseUrlBox" Text="http://localhost:11434/v1" />
                        <TextBlock x:Name="LocalHint"
                                   Style="{StaticResource Hint}"
                                   Text="Example: http://&lt;host&gt;:11434/v1. You can change this later in Settings." />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Step 3: Model -->
            <StackPanel x:Name="ModelPanel" Visibility="Collapsed">
                <TextBlock Style="{StaticResource StepTitle}" Text="Download the speech model" />
                <TextBlock Style="{StaticResource StepSubtitle}"
                           Text="Blurt transcribes on-device with Whisper. The selected model is fetched once and reused; if the download is blocked, install the file by hand using the link below." />
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock x:Name="ModelStatus"
                                   Style="{StaticResource BodyText}"
                                   Text="Checking for the model…" />
                        <ProgressBar x:Name="ModelProgress"
                                     Margin="0,14,0,0"
                                     IsIndeterminate="False"
                                     Minimum="0" Maximum="1"
                                     Visibility="Collapsed" />
                        <Button x:Name="DownloadButton"
                                Content="Download now"
                                Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Left"
                                Margin="0,14,0,0"
                                Visibility="Collapsed"
                                Click="OnDownloadModel" />
                        <TextBlock x:Name="ModelHint"
                                   Style="{StaticResource Hint}"
                                   Text="" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Step 4: Hotkeys -->
            <StackPanel x:Name="HotkeysPanel" Visibility="Collapsed">
                <TextBlock Style="{StaticResource StepTitle}" Text="Your hotkeys" />
                <TextBlock Style="{StaticResource StepSubtitle}"
                           Text="Hold a key and speak; release to insert the text at your cursor." />
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,5"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Text="Fix (clean German)" />
                        <TextBlock x:Name="HotkeyFix" Grid.Row="0" Grid.Column="1" Margin="0,5"
                                   FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,5"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Text="English" />
                        <TextBlock x:Name="HotkeyEnglish" Grid.Row="1" Grid.Column="1" Margin="0,5"
                                   FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,5"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Text="Flex slot" />
                        <TextBlock x:Name="HotkeyFlex" Grid.Row="2" Grid.Column="1" Margin="0,5"
                                   FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    </Grid>
                </Border>
                <TextBlock Style="{StaticResource Hint}"
                           Text="You can remap these any time from the tray icon → Settings. Blurt then runs quietly in the tray." />
            </StackPanel>

        </Grid>

        <!-- Navigation buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BackButton"
                    Content="Back"
                    Margin="0,0,10,0"
                    Click="OnBack" />
            <Button x:Name="SkipButton"
                    Content="Skip"
                    Margin="0,0,10,0"
                    Visibility="Collapsed"
                    Click="OnNext" />
            <Button x:Name="NextButton"
                    Content="Next"
                    Style="{StaticResource AccentButton}"
                    MinWidth="110"
                    IsDefault="True"
                    Click="OnNext" />
        </StackPanel>
    </Grid>
</Window>
