<Window x:Class="Blurt.App.TutorialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Title="How to use Blurt"
        Width="560" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        FontSize="13">
    <!-- Card title/body styles local; the surface/control templates and pill
         brushes come from Themes/Controls.xaml, merged by ThemeManager.Apply
         before InitializeComponent (issue 19). -->
    <Window.Resources>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="CardBody" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="21" />
        </Style>
    </Window.Resources>

    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="StepIndicator" Grid.Row="0"
                   FontSize="11"
                   Foreground="{DynamicResource TextTertiaryBrush}"
                   Margin="0,0,0,16"
                   Text="Lesson 1 of 5" />

        <!-- Animated demo stage: the real status pill plays the current concept,
             driven from Core's TutorialDemo cues so the lesson matches the app. -->
        <Border Grid.Row="1"
                Height="120"
                CornerRadius="12"
                Background="{DynamicResource TrackBrush}"
                Margin="0,0,0,22">
            <Border CornerRadius="17"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource PillBackgroundBrush}"
                    BorderBrush="{DynamicResource PillBorderBrush}"
                    BorderThickness="1"
                    Padding="16,9">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.35" Color="Black" />
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="DemoDot"
                             Width="10" Height="10"
                             VerticalAlignment="Center"
                             Fill="#DC3545" />
                    <TextBlock x:Name="DemoText"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PillTextBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="listening" />
                </StackPanel>
            </Border>
        </Border>

        <StackPanel Grid.Row="2">
            <TextBlock x:Name="CardTitleText" Style="{StaticResource CardTitle}" Text="Push to talk" />
            <TextBlock x:Name="CardBodyText" Style="{StaticResource CardBody}" Text="" />
        </StackPanel>

        <!-- Skippable any time; Back disabled on the first card; the last card's
             primary button reads "Got it" and closes. -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="SkipButton"
                    Content="Skip"
                    Margin="0,0,10,0"
                    Click="OnSkip" />
            <Button x:Name="BackButton"
                    Content="Back"
                    Margin="0,0,10,0"
                    Click="OnBack" />
            <Button x:Name="NextButton"
                    Content="Next"
                    Style="{StaticResource AccentButton}"
                    MinWidth="110"
                    IsDefault="True"
                    Click="OnNext" />
        </StackPanel>
    </Grid>
</Window>
